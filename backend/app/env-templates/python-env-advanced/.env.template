# Environment Identification
ENV_ID=${ENV_ID}
AGENT_ID=${AGENT_ID}
ENV_NAME=${ENV_NAME}
ENV_VERSION=${ENV_VERSION}

# Network Configuration
AGENT_PORT=${AGENT_PORT}

# Security
AGENT_AUTH_TOKEN=${AGENT_AUTH_TOKEN}

# Database (optional - for agent to access main DB)
DATABASE_URL=${DATABASE_URL}

# Resource Limits
CPU_LIMIT=${CPU_LIMIT:-1.0}
MEMORY_LIMIT=${MEMORY_LIMIT:-512M}
CPU_RESERVATION=${CPU_RESERVATION:-0.25}
MEMORY_RESERVATION=${MEMORY_RESERVATION:-128M}

# Agent Configuration (will be set dynamically)
WORKFLOW_PROMPT=${WORKFLOW_PROMPT}
ENTRYPOINT_PROMPT=${ENTRYPOINT_PROMPT}

# Logging
LOG_LEVEL=INFO

# Claude Code Configuration
CLAUDE_CODE_WORKSPACE=/app/app
CLAUDE_CODE_PERMISSION_MODE=acceptEdits
